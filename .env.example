TXLINE_API_KEY=              # from TxODDS hackathon signup (via Solana sign-up per track rules)
TXLINE_BASE_URL=             # from TxLINE docs; do not guess

# Off by default to stay World Cup-only (PRD NG-5). Set to true to also surface
# the International Friendlies bundle — handy for exercising the loop when no
# World Cup fixture is live or upcoming.
INCLUDE_FRIENDLIES=false

# Runs the engine in Replay Mode (FR-1.3) at 60x speed using fixtures/replay data
REPLAY_MODE=false

# ── API-Football ──────────────────────────────────────────────────────────────
# TxLINE has no player names or match events — this is a separate provider
# used only for the Match page's Timeline + Lineups tabs.
# Sign up free at https://www.api-football.com (dashboard) — 100 req/day free tier.
API_FOOTBALL_KEY=
# Only set this if you're using RapidAPI instead of the direct dashboard:
# API_FOOTBALL_BASE_URL=https://api-football-v1.p.rapidapi.com/v3

# ── Supabase ───────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Connect → Framework (Next.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# From: Supabase Dashboard → Project Settings → API → Service Role Key
# (click "Reveal" — keep this secret, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# DATABASE_URL is NOT needed — all DB access uses the Supabase JS client.

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com

# Run: pnpm gen:treasury  → prints the key + public address
TREASURY_SECRET_KEY=

# Run: pnpm create:tree  → prints the tree address (after TREASURY_SECRET_KEY is set)
MERKLE_TREE_ADDRESS=

# Optional: collection mint address (set after creating a Bubblegum collection)
COLLECTION_MINT_ADDRESS=

# Public app URL (used for self-hosted metadata URIs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
